#!/usr/bin/env bash
# visible-text — Check if visible text is present.
# Usage: scripts/native-agent/visible-text <text> [timeout_ms]
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
[ -z "${1:-}" ] && { echo "Usage: visible-text <text> [timeout_ms]" >&2; exit 1; }
TIMEOUT="${2:-2000}"
python3 -c "
import json, sys
print(json.dumps({'action':'visible-text','text':sys.argv[1],'timeout':int(sys.argv[2])}))
" "$1" "$TIMEOUT" | "$DIR/_send"
