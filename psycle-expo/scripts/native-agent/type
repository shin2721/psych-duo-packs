#!/usr/bin/env bash
# type — Type text into an element by testID.
# Usage: scripts/native-agent/type <testID> <text>
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
[ -z "${1:-}" ] || [ -z "${2:-}" ] && { echo "Usage: type <testID> <text>" >&2; exit 1; }
python3 -c "
import json, sys
print(json.dumps({'action':'type','id':sys.argv[1],'text':sys.argv[2]}))
" "$1" "$2" | "$DIR/_send"
