#!/usr/bin/env bash
# clear — Clear text in an input by testID.
# Usage: scripts/native-agent/clear <testID>
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
[ -z "${1:-}" ] && { echo "Usage: clear <testID>" >&2; exit 1; }
python3 -c "
import json, sys
print(json.dumps({'action':'clear','id':sys.argv[1]}))
" "$1" | "$DIR/_send"
