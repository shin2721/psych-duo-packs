#!/usr/bin/env bash
# swipe — Swipe an element by testID.
# Usage: scripts/native-agent/swipe <testID> <up|down|left|right> [speed] [percent]
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
[ -z "${1:-}" ] || [ -z "${2:-}" ] && { echo "Usage: swipe <testID> <direction> [speed] [percent]" >&2; exit 1; }
SPEED="${3:-slow}"
PCT="${4:-0.5}"
python3 -c "
import json, sys
print(json.dumps({
    'action':'swipe',
    'id':sys.argv[1],
    'direction':sys.argv[2],
    'speed':sys.argv[3],
    'percent':float(sys.argv[4]),
}))
" "$1" "$2" "$SPEED" "$PCT" | "$DIR/_send"
